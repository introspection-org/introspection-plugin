# Introspection MCP server registration for Codex CLI.
# Merge into ~/.codex/config.toml, then set the environment variables
# INTROSPECTION_MCP_URL and INTROSPECTION_API_TOKEN in your shell profile
# (see the repo README's Auth section). Requires a Codex CLI version with
# remote (streamable HTTP) MCP support — for older versions, front the URL
# with a stdio HTTP-bridge proxy of your choice.

[mcp_servers.introspection]
url = "${INTROSPECTION_MCP_URL}"

[mcp_servers.introspection.http_headers]
Authorization = "Bearer ${INTROSPECTION_API_TOKEN}"
